<%- include('../partials/header') %>

<section class="section admin-section">
  <div class="container">
    <div class="admin-header">
      <h1>Заказ №<%= order.id %></h1>
      <nav class="admin-nav">
        <% adminNav.forEach(n => { %>
          <a href="<%= n.href %>" class="<%= n.href === '/admin/orders' ? 'active' : '' %>"><%= n.label %></a>
        <% }) %>
      </nav>
    </div>

    <p><a href="/admin/orders">← К заказам</a></p>
    <% if (message === 'updated') { %><div class="alert alert-success">Заказ обновлён</div><% } %>
    <% if (message === 'photo_added') { %><div class="alert alert-success">Фото этапа добавлено</div><% } %>
    <% if (message === 'photo_deleted') { %><div class="alert alert-success">Фото удалено</div><% } %>

    <div class="admin-two-col">
      <div class="admin-form-card">
        <h2>Информация</h2>
        <dl class="info-list">
          <dt>Товар</dt><dd><%= order.product_title %></dd>
          <dt>Клиент</dt><dd><%= order.customer_name %><% if (order.login) { %> (@<%= order.login %>)<% } %></dd>
          <dt>Телефон</dt><dd><%= order.phone %></dd>
          <dt>Email</dt><dd><%= order.email || '—' %></dd>
          <dt>Сумма</dt><dd><%= order.amount.toLocaleString('ru-RU') %> ₽</dd>
          <dt>Дата</dt><dd><%= new Date(order.created_at).toLocaleString('ru-RU') %></dd>
        </dl>
      </div>

      <div class="admin-form-card">
        <h2>Управление заказом</h2>
        <form method="POST" action="/admin/orders/<%= order.id %>/update" class="form">
          <div class="form-group">
            <label for="status">Статус / этап</label>
            <select id="status" name="status">
              <% ['new','processing','paid','shipped','done','cancelled'].forEach(s => { %>
                <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label for="estimated_date">Срок готовности</label>
            <input type="date" id="estimated_date" name="estimated_date" value="<%= order.estimated_date || '' %>">
          </div>
          <div class="form-group">
            <label for="stage_note">Комментарий для клиента</label>
            <textarea id="stage_note" name="stage_note" rows="2"><%= order.stage_note || '' %></textarea>
          </div>

          <% if (order.media_request) { %>
            <div class="request-box">
              <strong>Запрос фото/видео:</strong>
              <p><%= order.media_request %></p>
              <div class="form-group">
                <label>Статус запроса</label>
                <select name="media_request_status">
                  <option value="pending" <%= order.media_request_status === 'pending' ? 'selected' : '' %>>Ожидает</option>
                  <option value="done" <%= order.media_request_status === 'done' ? 'selected' : '' %>>Выполнен</option>
                  <option value="rejected" <%= order.media_request_status === 'rejected' ? 'selected' : '' %>>Отклонён</option>
                </select>
              </div>
            </div>
          <% } else { %>
            <input type="hidden" name="media_request_status" value="<%= order.media_request_status || '' %>">
          <% } %>

          <% if (order.change_request) { %>
            <div class="request-box">
              <strong>Запрос на изменение:</strong>
              <p><%= order.change_request %></p>
              <div class="form-group">
                <label>Статус запроса</label>
                <select name="change_request_status">
                  <option value="pending" <%= order.change_request_status === 'pending' ? 'selected' : '' %>>На рассмотрении</option>
                  <option value="approved" <%= order.change_request_status === 'approved' ? 'selected' : '' %>>Одобрено</option>
                  <option value="rejected" <%= order.change_request_status === 'rejected' ? 'selected' : '' %>>Отклонено</option>
                </select>
              </div>
            </div>
          <% } else { %>
            <input type="hidden" name="change_request_status" value="<%= order.change_request_status || '' %>">
          <% } %>

          <button type="submit" class="btn btn-gold">Сохранить</button>
        </form>
      </div>
    </div>

    <div class="admin-form-card mt-lg">
      <h2>Фото этапов пошива</h2>
      <p class="hint">Клиент увидит эти фото в личном кабинете.</p>
      <% if (progressPhotos && progressPhotos.length > 0) { %>
        <div class="progress-photos-grid admin-progress-photos">
          <% progressPhotos.forEach(p => { %>
            <figure class="progress-photo-item">
              <img src="<%= p.image_path %>" alt="">
              <% if (p.caption) { %><figcaption><%= p.caption %></figcaption><% } %>
              <form method="POST" action="/admin/orders/<%= order.id %>/photos/<%= p.id %>/delete" class="inline-form"
                onsubmit="return confirm('Удалить фото?');">
                <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
              </form>
            </figure>
          <% }) %>
        </div>
      <% } else { %>
        <p class="empty-state">Фото этапов пока нет.</p>
      <% } %>
      <form method="POST" action="/admin/orders/<%= order.id %>/photos" enctype="multipart/form-data" class="form mt-md">
        <div class="form-row">
          <div class="form-group">
            <label for="photo">Загрузить фото</label>
            <input type="file" id="photo" name="photo" accept=".jpg,.jpeg,.png,.webp,image/*" required>
          </div>
          <div class="form-group">
            <label for="caption">Подпись</label>
            <input type="text" id="caption" name="caption" placeholder="Например: Раскрой ткани">
          </div>
        </div>
        <button type="submit" class="btn btn-gold btn-sm">Добавить фото</button>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
