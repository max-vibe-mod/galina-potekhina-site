ÔĽŅ<%- include('partials/header') %>

<section class="section dashboard-section">
  <div class="container">
    <div class="dashboard-header reveal">
      <div>
        <span class="section-label">Client Area</span>
        <h1>–†‚Äļ–†—Ď–°‚Ä°–†–Ö–°‚ÄĻ–†‚ĄĖ –†—Ē–†¬į–†¬Ī–†—Ď–†–Ö–†¬Ķ–°‚Äö</h1>
      </div>
    </div>

    <% if (saved === 'profile') { %><div class="alert alert-success">–†—ü–°–ā–†—ē–°‚Äě–†—Ď–†¬Ľ–°–ä –†—ē–†¬Ī–†–Ö–†—ē–†–Ü–†¬Ľ–°‚Äė–†–Ö</div><% } %>
    <% if (saved === 'measurements') { %><div class="alert alert-success">–†—ö–†¬Ķ–°–ā–†—Ē–†—Ď –°–É–†—ē–°‚Ä¶–°–ā–†¬į–†–Ö–†¬Ķ–†–Ö–°‚ÄĻ</div><% } %>
    <% if (saved === 'fitting') { %><div class="alert alert-success">–†‚ÄĒ–†¬į–†—ó–†—Ď–°–É–°–ä –†–Ö–†¬į –†—ó–°–ā–†—Ď–†—ė–†¬Ķ–°–ā–†—Ē–°—ď –†—ó–†—ē–†“Ď–°‚Äö–†–Ü–†¬Ķ–°–ā–†¬∂–†“Ď–†¬Ķ–†–Ö–†¬į</div><% } %>
    <% if (saved === 'cancel') { %><div class="alert alert-success">–†‚ÄĒ–†¬į–†—Ē–†¬į–†¬∑ –†—ē–°‚Äö–†—ė–†¬Ķ–†–Ö–°‚Äė–†–Ö</div><% } %>
    <% if (saved === 'media') { %><div class="alert alert-success">–†‚ÄĒ–†¬į–†—ó–°–ā–†—ē–°–É –°‚Äě–†—ē–°‚Äö–†—ē/–†–Ü–†—Ď–†“Ď–†¬Ķ–†—ē –†—ē–°‚Äö–†—ó–°–ā–†¬į–†–Ü–†¬Ľ–†¬Ķ–†–Ö</div><% } %>
    <% if (saved === 'change') { %><div class="alert alert-success">–†‚ÄĒ–†¬į–†—ó–°–ā–†—ē–°–É –†–Ö–†¬į –†—Ď–†¬∑–†—ė–†¬Ķ–†–Ö–†¬Ķ–†–Ö–†—Ď–†¬Ķ –†—ē–°‚Äö–†—ó–°–ā–†¬į–†–Ü–†¬Ľ–†¬Ķ–†–Ö</div><% } %>
    <% if (error === 'slot') { %><div class="alert alert-error">–†¬≠–°‚Äö–†—ē –†–Ü–°–ā–†¬Ķ–†—ė–°–Ź –°—ď–†¬∂–†¬Ķ –†¬∑–†¬į–†–Ö–°–Ź–°‚Äö–†—ē</div><% } %>
    <% if (error === 'cancel') { %><div class="alert alert-error">–†—ú–†¬Ķ–†¬Ľ–°–ä–†¬∑–°–Ź –†—ē–°‚Äö–†—ė–†¬Ķ–†–Ö–†—Ď–°‚Äö–°–ä –°–Ć–°‚Äö–†—ē–°‚Äö –†¬∑–†¬į–†—Ē–†¬į–†¬∑</div><% } %>
    <% if (error === 'confirm') { %><div class="alert alert-error">–†—ü–†—ē–†“Ď–°‚Äö–†–Ü–†¬Ķ–°–ā–†“Ď–†—Ď–°‚Äö–†¬Ķ, –°‚Ä°–°‚Äö–†—ē –°–É–†—ē–†—Ė–†¬Ľ–†¬į–°–É–†–Ö–°‚ÄĻ –°–É –†–Ü–†—ē–†¬∑–†—ė–†—ē–†¬∂–†–Ö–†—ē–†‚ĄĖ –†“Ď–†—ē–†—ó–†¬Ľ–†¬į–°‚Äö–†—ē–†‚ĄĖ</div><% } %>
    <% if (error === 'empty') { %><div class="alert alert-error">–†‚ÄĒ–†¬į–†—ó–†—ē–†¬Ľ–†–Ö–†—Ď–°‚Äö–†¬Ķ –°‚Äö–†¬Ķ–†—Ē–°–É–°‚Äö –†¬∑–†¬į–†—ó–°–ā–†—ē–°–É–†¬į</div><% } %>

    <nav class="dashboard-nav reveal">
      <a href="#overview" class="dash-nav-link active">–†—õ–†¬Ī–†¬∑–†—ē–°–ā</a>
      <a href="#bonuses" class="dash-nav-link">–†‚Äė–†—ē–†–Ö–°—ď–°–É–°‚ÄĻ</a>
      <a href="#orders-active" class="dash-nav-link">–†‚ÄĒ–†¬į–†—Ē–†¬į–†¬∑–°‚ÄĻ</a>
      <a href="#rentals" class="dash-nav-link">–†—í–°–ā–†¬Ķ–†–Ö–†“Ď–†¬į</a>
      <a href="#measurements" class="dash-nav-link">–†—ö–†¬Ķ–°–ā–†—Ē–†—Ď</a>
      <a href="#fitting" class="dash-nav-link">–†—ü–°–ā–†—Ď–†—ė–†¬Ķ–°–ā–†—Ē–†¬į</a>
    </nav>

    <div id="overview" class="dashboard-block reveal">
      <div class="account-grid">
        <div class="loyalty-card">
          <div class="loyalty-card-inner loyalty-card-inner--premium">
            <div class="loyalty-card-shine"></div>
            <div class="loyalty-card-chip" aria-hidden="true"></div>
            <div class="loyalty-card-top">
              <span class="logo-frame logo-frame--xs">
                <img src="/logo.png?v=9" alt="–†–é–°‚Äö–°—ď–†“Ď–†—Ď–°–Ź –†—ó–†—ē–°‚ā¨–†—Ď–†–Ü–†¬į –†‚Äú–†¬į–†¬Ľ–†—Ď–†–Ö–°‚ÄĻ –†—ü–†—ē–°‚Äö–†¬Ķ–°‚Ä¶–†—Ď–†–Ö–†—ē–†‚ĄĖ" class="loyalty-logo">
              </span>
              <span class="loyalty-brand">Galina Potekhina</span>
            </div>
            <p class="loyalty-label">–†—ô–†¬į–°–ā–°‚Äö–†¬į –†¬Ľ–†—ē–°–Ź–†¬Ľ–°–ä–†–Ö–†—ē–°–É–°‚Äö–†—Ď</p>
            <p class="loyalty-login"><%= user.login %></p>
            <div class="loyalty-balance">
              <span class="balance-label">–†‚Äė–†¬į–†¬Ľ–†¬į–†–Ö–°–É</span>
              <span class="balance-value"><%= Math.floor(bonusBalance).toLocaleString('ru-RU') %> –≤‚Äö–Ö</span>
            </div>
          </div>
        </div>
        <div class="account-info">
          <h2>–†—ü–°–ā–†—ē–°‚Äě–†—Ď–†¬Ľ–°–ä</h2>
          <form method="POST" action="/account/profile" class="form form-luxury">
            <div class="form-group">
              <label>–†‚Äļ–†—ē–†—Ė–†—Ď–†–Ö</label>
              <input type="text" value="<%= user.login %>" disabled>
            </div>
            <div class="form-group">
              <label for="full_name">–†¬ė–†—ė–°–Ź / –†¬§–†¬ė–†—õ</label>
              <input type="text" id="full_name" name="full_name" value="<%= user.full_name || '' %>">
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" value="<%= user.email || '' %>">
            </div>
            <div class="form-group">
              <label for="phone">–†—ě–†¬Ķ–†¬Ľ–†¬Ķ–°‚Äě–†—ē–†–Ö</label>
              <input type="tel" id="phone" name="phone" value="<%= user.phone || '' %>">
            </div>
            <button type="submit" class="btn btn-luxury btn-sm">–†–é–†—ē–°‚Ä¶–°–ā–†¬į–†–Ö–†—Ď–°‚Äö–°–ä</button>
          </form>
          <p class="hint">–†¬†–†¬Ķ–†—Ė–†—Ď–°–É–°‚Äö–°–ā–†¬į–°‚Ä†–†—Ď–°–Ź: <%= new Date(user.created_at).toLocaleDateString('ru-RU') %></p>
        </div>
      </div>
    </div>

    <div id="bonuses" class="dashboard-block reveal">
      <h2>–†—ô–†¬Ľ–°—ď–†¬Ī –†—ó–°–ā–†—Ď–†–Ü–†—Ď–†¬Ľ–†¬Ķ–†—Ė–†—Ď–†‚ĄĖ</h2>
      <p class="block-desc">–†‚Äė–†—ē–†–Ö–°—ď–°–É–°‚ÄĻ –†–Ö–†¬į–°‚Ä°–†—Ď–°–É–†¬Ľ–°–Ź–°–č–°‚Äö–°–É–°–Ź –†¬į–†–Ü–°‚Äö–†—ē–†—ė–†¬į–°‚Äö–†—Ď–°‚Ä°–†¬Ķ–°–É–†—Ē–†—Ď –†—ó–°–ā–†—Ď –†¬∑–†¬į–†—Ē–†¬į–†¬∑–†¬į–°‚Ä¶ –†—Ď –†“Ď–†¬Ķ–†‚ĄĖ–°–É–°‚Äö–†–Ü–°—ď–°–č–°‚Äö <%= bonusRules.BONUS_DAYS %> –†“Ď–†–Ö–†¬Ķ–†‚ĄĖ.</p>
      <ul class="bonus-info bonus-info-card">
        <li>–†—ü–†¬Ķ–°–ā–†–Ü–°‚ÄĻ–†‚ĄĖ –†¬∑–†¬į–†—Ē–†¬į–†¬∑ –†—ē–°‚Äö <%= bonusRules.BONUS_THRESHOLD.toLocaleString('ru-RU') %> –≤‚Äö–Ö –≤–ā‚ÄĚ <strong><%= bonusRules.FIRST_ORDER_BONUS %> –†¬Ī–†—ē–†–Ö–°—ď–°–É–†—ē–†–Ü</strong></li>
        <li>–†—ô–†¬į–†¬∂–†“Ď–°‚ÄĻ–†‚ĄĖ –†¬∑–†¬į–†—Ē–†¬į–†¬∑ –†—ē–°‚Äö <%= bonusRules.BONUS_THRESHOLD.toLocaleString('ru-RU') %> –≤‚Äö–Ö –≤–ā‚ÄĚ <strong>+<%= bonusRules.BONUS_PERCENT * 100 %>%</strong></li>
        <li>–†—ě–†¬Ķ–†—Ē–°—ď–°‚Äį–†—Ď–†‚ĄĖ –†¬Ī–†¬į–†¬Ľ–†¬į–†–Ö–°–É: <strong><%= Math.floor(bonusBalance).toLocaleString('ru-RU') %> –≤‚Äö–Ö</strong></li>
      </ul>
      <% if (bonusHistory.length > 0) { %>
        <div class="table-wrap">
          <table class="data-table">
            <thead><tr><th>–†‚ÄĚ–†¬į–°‚Äö–†¬į</th><th>–†—ú–†¬į–°‚Ä°–†—Ď–°–É–†¬Ľ–†¬Ķ–†–Ö–†—ē</th><th>–†—õ–°–É–°‚Äö–†¬į–°‚Äö–†—ē–†—Ē</th><th>–†¬ė–°–É–°‚Äö–†¬Ķ–†—Ē–†¬į–†¬Ķ–°‚Äö</th><th>–†–é–°‚Äö–†¬į–°‚Äö–°—ď–°–É</th></tr></thead>
            <tbody>
              <% bonusHistory.forEach(b => { %>
                <tr class="<%= b.expired ? 'row-expired' : '' %>">
                  <td><%= new Date(b.earned_at).toLocaleDateString('ru-RU') %></td>
                  <td><%= b.amount %> –≤‚Äö–Ö</td>
                  <td><%= b.remaining %> –≤‚Äö–Ö</td>
                  <td><%= new Date(b.expires_at).toLocaleDateString('ru-RU') %></td>
                  <td><%= b.expired ? '–†–é–†—Ė–†—ē–°–ā–†¬Ķ–†¬Ľ–†—Ď' : (b.remaining > 0 ? '–†—í–†—Ē–°‚Äö–†—Ď–†–Ü–†–Ö–°‚ÄĻ' : '–†¬ė–°–É–†—ó–†—ē–†¬Ľ–°–ä–†¬∑–†—ē–†–Ü–†¬į–†–Ö–°‚ÄĻ') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div id="orders-active" class="dashboard-block reveal">
      <h2>–†—ö–†—ē–†—Ď –†¬∑–†¬į–†—Ē–†¬į–†¬∑–°‚ÄĻ</h2>
      <% if (activeOrders.length === 0 && pastOrders.length === 0) { %>
        <p class="empty-state">–†—ú–†¬Ķ–°‚Äö –†¬∑–†¬į–†—Ē–†¬į–†¬∑–†—ē–†–Ü. <a href="/#gallery">–†‚Äô–°‚ÄĻ–†¬Ī–°–ā–†¬į–°‚Äö–°–ä –†—ė–†—ē–†“Ď–†¬Ķ–†¬Ľ–°–ä</a></p>
      <% } %>

      <% if (activeOrders.length > 0) { %>
        <h3 class="subsection-title">–†—ě–†¬Ķ–†—Ē–°—ď–°‚Äį–†—Ď–†¬Ķ</h3>
        <div class="order-cards">
          <% activeOrders.forEach(o => { %>
            <article class="order-card order-card-full">
              <div class="order-card-head">
                <span class="order-id">–≤‚Äě‚Äď<%= o.id %></span>
                <span class="order-status"><%= o.progressInfo.label %></span>
              </div>
              <h3><%= o.product_title %></h3>
              <p class="order-meta"><%= o.amount.toLocaleString('ru-RU') %> –≤‚Äö–Ö –í¬∑ –†—ē–°‚Äě–†—ē–°–ā–†—ė–†¬Ľ–†¬Ķ–†–Ö <%= new Date(o.created_at).toLocaleDateString('ru-RU') %></p>
              <p class="order-stage-desc"><%= o.progressInfo.desc %></p>
              <% if (o.estimated_date) { %>
                <p class="order-deadline"><strong>–†—õ–°–ā–†—Ď–†¬Ķ–†–Ö–°‚Äö–†—Ď–°–ā–†—ē–†–Ü–†—ē–°‚Ä°–†–Ö–°‚ÄĻ–†‚ĄĖ –°–É–°–ā–†—ē–†—Ē:</strong> <%= new Date(o.estimated_date).toLocaleDateString('ru-RU') %></p>
              <% } %>
              <% if (o.stage_note) { %>
                <p class="order-admin-note"><strong>–†—ô–†—ē–†—ė–†—ė–†¬Ķ–†–Ö–°‚Äö–†¬į–°–ā–†—Ď–†‚ĄĖ –†¬į–°‚Äö–†¬Ķ–†¬Ľ–°–ä–†¬Ķ:</strong> <%= o.stage_note %></p>
              <% } %>
              <% if (o.progressPhotos && o.progressPhotos.length > 0) { %>
                <div class="progress-photos">
                  <p class="subsection-title-sm">–†¬§–†—ē–°‚Äö–†—ē –°–Ć–°‚Äö–†¬į–†—ó–†—ē–†–Ü –†—ó–†—ē–°‚ā¨–†—Ď–†–Ü–†¬į</p>
                  <div class="progress-photos-grid">
                    <% o.progressPhotos.forEach(p => { %>
                      <figure class="progress-photo-item">
                        <a href="<%= p.image_path %>" target="_blank" rel="noopener">
                          <img src="<%= p.image_path %>" alt="<%= p.caption || '–†¬≠–°‚Äö–†¬į–†—ó –†—ó–†—ē–°‚ā¨–†—Ď–†–Ü–†¬į' %>" loading="lazy">
                        </a>
                        <% if (p.caption) { %><figcaption><%= p.caption %></figcaption><% } %>
                      </figure>
                    <% }) %>
                  </div>
                </div>
              <% } %>
              <div class="progress-wrap">
                <div class="progress-bar" style="width: <%= o.progressInfo.progress %>%"></div>
              </div>
              <div class="progress-steps progress-steps--icons">
                <% const stepIcons = ['–≤—ö‚Äú', '–≤—ö‚Äö', '–≤‚ÄĒ‚Äį', '–≤‚ÄĒ‚Ä°', '–≤¬ė‚Ä¶']; %>
                <% const stepLabels = ['–†—ü–°–ā–†—Ď–†–Ö–°–Ź–°‚Äö', '–†—ü–†—ē–°‚ā¨–†—Ď–†–Ü', '–†—ü–°–ā–†—Ď–†—ė–†¬Ķ–°–ā–†—Ē–†¬į', '–†¬§–†—Ď–†–Ö–†¬į–†¬Ľ', '–†‚Äú–†—ē–°‚Äö–†—ē–†–Ü–†—ē']; %>
                <% stepLabels.forEach((step, i) => { %>
                  <span class="progress-step<%= i <= o.progressInfo.step ? ' done' : '' %>">
                    <span class="step-icon" aria-hidden="true"><%= stepIcons[i] %></span>
                    <span class="step-label"><%= step %></span>
                  </span>
                <% }) %>
              </div>

              <div class="order-actions">
                <details class="order-action-block">
                  <summary>–†‚ÄĒ–†¬į–†—ó–°–ā–†—ē–°–É–†—Ď–°‚Äö–°–ä –°‚Äě–†—ē–°‚Äö–†—ē / –†–Ü–†—Ď–†“Ď–†¬Ķ–†—ē –†—ē–°‚Äö–°‚Ä°–°‚Äė–°‚Äö</summary>
                  <form method="POST" action="/account/orders/<%= o.id %>/media-request" class="form form-luxury">
                    <div class="form-group">
                      <textarea name="media_request" rows="2" placeholder="–†¬ß–°‚Äö–†—ē –°‚Ä¶–†—ē–°‚Äö–†—Ď–°‚Äö–†¬Ķ –°—ď–†–Ü–†—Ď–†“Ď–†¬Ķ–°‚Äö–°–ä –†–Ö–†¬į –°‚Äě–†—ē–°‚Äö–†—ē –†—Ď–†¬Ľ–†—Ď –†–Ü–†—Ď–†“Ď–†¬Ķ–†—ē?" required><%= o.media_request || '' %></textarea>
                    </div>
                    <% if (o.media_request_status) { %>
                      <p class="hint">–†–é–°‚Äö–†¬į–°‚Äö–°—ď–°–É: <%= o.media_request_status === 'pending' ? '–†—õ–†¬∂–†—Ď–†“Ď–†¬į–†¬Ķ–°‚Äö –†—ē–°‚Äö–†–Ü–†¬Ķ–°‚Äö–†¬į' : o.media_request_status %></p>
                    <% } %>
                    <button type="submit" class="btn btn-outline btn-sm">–†—õ–°‚Äö–†—ó–°–ā–†¬į–†–Ü–†—Ď–°‚Äö–°–ä –†¬∑–†¬į–†—ó–°–ā–†—ē–°–É</button>
                  </form>
                </details>

                <details class="order-action-block">
                  <summary>–†‚Äô–†–Ö–†¬Ķ–°–É–°‚Äö–†—Ď –†—Ď–†¬∑–†—ė–†¬Ķ–†–Ö–†¬Ķ–†–Ö–†—Ď–°–Ź –†–Ü –†¬∑–†¬į–†—Ē–†¬į–†¬∑</summary>
                  <div class="warning-box">
                    –†—ü–°–ā–†—Ď –†—Ď–†¬∑–†—ė–†¬Ķ–†–Ö–†¬Ķ–†–Ö–†—Ď–†—Ď –†¬∑–†¬į–†—Ē–†¬į–†¬∑–†¬į –†–Ü–†—ē–†¬∑–†—ė–†—ē–†¬∂–†–Ö–†¬į –†“Ď–†—ē–†—ó–†—ē–†¬Ľ–†–Ö–†—Ď–°‚Äö–†¬Ķ–†¬Ľ–°–ä–†–Ö–†¬į–°–Ź –†—ē–†—ó–†¬Ľ–†¬į–°‚Äö–†¬į –≤–ā‚ÄĚ –†—ó–†—ē –†“Ď–†—ē–†—Ė–†—ē–†–Ü–†—ē–°–ā–°‚Äė–†–Ö–†–Ö–†—ē–°–É–°‚Äö–†—Ď –°–É –†¬į–°‚Äö–†¬Ķ–†¬Ľ–°–ä–†¬Ķ.
                  </div>
                  <form method="POST" action="/account/orders/<%= o.id %>/change-request" class="form form-luxury">
                    <div class="form-group">
                      <textarea name="change_request" rows="3" placeholder="–†—õ–†—ó–†—Ď–°‚ā¨–†—Ď–°‚Äö–†¬Ķ –†¬∂–†¬Ķ–†¬Ľ–†¬į–†¬Ķ–†—ė–°‚ÄĻ–†¬Ķ –†—Ď–†¬∑–†—ė–†¬Ķ–†–Ö–†¬Ķ–†–Ö–†—Ď–°–Ź" required><%= o.change_request || '' %></textarea>
                    </div>
                    <label class="checkbox-inline">
                      <input type="checkbox" name="confirm_extra" required>
                      –†—ü–†—ē–†–Ö–†—Ď–†—ė–†¬į–°–č, –°‚Ä°–°‚Äö–†—ē –†–Ü–†—ē–†¬∑–†—ė–†—ē–†¬∂–†–Ö–†¬į –†“Ď–†—ē–†—ó–†¬Ľ–†¬į–°‚Äö–†¬į
                    </label>
                    <% if (o.change_request_status) { %>
                      <p class="hint">–†–é–°‚Äö–†¬į–°‚Äö–°—ď–°–É: <%= o.change_request_status === 'pending' ? '–†—ú–†¬į –°–ā–†¬į–°–É–°–É–†—ė–†—ē–°‚Äö–°–ā–†¬Ķ–†–Ö–†—Ď–†—Ď' : o.change_request_status %></p>
                    <% } %>
                    <button type="submit" class="btn btn-outline btn-sm">–†—õ–°‚Äö–†—ó–°–ā–†¬į–†–Ü–†—Ď–°‚Äö–°–ä</button>
                  </form>
                </details>

                <% if (o.canCancel) { %>
                  <form method="POST" action="/account/orders/<%= o.id %>/cancel" class="cancel-form" onsubmit="return confirm('–†—õ–°‚Äö–†—ė–†¬Ķ–†–Ö–†—Ď–°‚Äö–°–ä –†¬∑–†¬į–†—Ē–†¬į–†¬∑ –≤‚Äě‚Äď<%= o.id %>?')">
                    <button type="submit" class="btn btn-ghost btn-sm btn-cancel">–†—õ–°‚Äö–†—ė–†¬Ķ–†–Ö–†—Ď–°‚Äö–°–ä –†¬∑–†¬į–†—Ē–†¬į–†¬∑</button>
                  </form>
                <% } %>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>

      <% if (pastOrders.length > 0) { %>
        <h3 class="subsection-title mt-md">–†¬ė–°–É–°‚Äö–†—ē–°–ā–†—Ď–°–Ź</h3>
        <div class="table-wrap">
          <table class="data-table">
            <thead><tr><th>–≤‚Äě‚Äď</th><th>–†—ě–†—ē–†–Ü–†¬į–°–ā</th><th>–†–é–°—ď–†—ė–†—ė–†¬į</th><th>–†–é–°‚Äö–†¬į–°‚Äö–°—ď–°–É</th><th>–†‚ÄĚ–†¬į–°‚Äö–†¬į</th></tr></thead>
            <tbody>
              <% pastOrders.forEach(o => { %>
                <tr>
                  <td><%= o.id %></td>
                  <td><%= o.product_title %></td>
                  <td><%= o.amount.toLocaleString('ru-RU') %> –≤‚Äö–Ö</td>
                  <td><span class="status status-<%= o.status %>"><%= o.progressInfo.label %></span></td>
                  <td><%= new Date(o.created_at).toLocaleDateString('ru-RU') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div id="rentals" class="dashboard-block reveal">
      <h2>–†¬ė–°–É–°‚Äö–†—ē–°–ā–†—Ď–°–Ź –†¬į–°–ā–†¬Ķ–†–Ö–†“Ď–°‚ÄĻ</h2>
      <% if (!rentals || rentals.length === 0) { %>
        <p class="empty-state">–†—ú–†¬Ķ–°‚Äö –†¬∑–†¬į–°–Ź–†–Ü–†—ē–†—Ē –†–Ö–†¬į –†¬į–°–ā–†¬Ķ–†–Ö–†“Ď–°—ď. <a href="/#rental">–†—ü–†—ē–°–É–†—ė–†—ē–°‚Äö–°–ā–†¬Ķ–°‚Äö–°–ä –†—Ē–†¬į–°‚Äö–†¬į–†¬Ľ–†—ē–†—Ė</a></p>
      <% } else { %>
        <div class="table-wrap">
          <table class="data-table">
            <thead><tr><th>–≤‚Äě‚Äď</th><th>–†‚Äô–†¬Ķ–°‚Äį–°–ä</th><th>–†—ü–†¬Ķ–°–ā–†—Ď–†—ē–†“Ď</th><th>–†–é–°—ď–†—ė–†—ė–†¬į</th><th>–†–é–°‚Äö–†¬į–°‚Äö–°—ď–°–É</th></tr></thead>
            <tbody>
              <% rentals.forEach(r => { %>
                <tr>
                  <td><%= r.id %></td>
                  <td><%= r.item_title %></td>
                  <td><%= r.rent_from %> –≤–ā‚ÄĚ <%= r.rent_to %></td>
                  <td><%= r.amount ? r.amount.toLocaleString('ru-RU') + ' –≤‚Äö–Ö' : '–≤–ā‚ÄĚ' %></td>
                  <td><span class="status status-<%= r.status %>"><%= r.status %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div id="measurements" class="dashboard-block reveal">
      <h2>–†—ö–†—ē–†—Ď –†—ė–†¬Ķ–°–ā–†—Ē–†—Ď</h2>
      <p class="block-desc">–†—ü–†¬į–°–ā–†¬į–†—ė–†¬Ķ–°‚Äö–°–ā–°‚ÄĻ –†–Ü –°–É–†¬į–†–Ö–°‚Äö–†—Ď–†—ė–†¬Ķ–°‚Äö–°–ā–†¬į–°‚Ä¶ –†“Ď–†¬Ľ–°–Ź –†—Ď–†–Ö–†“Ď–†—Ď–†–Ü–†—Ď–†“Ď–°—ď–†¬į–†¬Ľ–°–ä–†–Ö–†—ē–†—Ė–†—ē –†—ó–†—ē–°‚ā¨–†—Ď–†–Ü–†¬į.</p>
      <form method="POST" action="/account/measurements" class="form form-luxury measurements-form">
        <div class="measurements-grid">
          <% const m = measurements || {}; %>
          <% const fields = [
            ['chest', '–†—õ–†¬Ī–°‚Ä¶–†–Ü–†¬į–°‚Äö –†—Ė–°–ā–°—ď–†“Ď–†—Ď'], ['waist', '–†—ě–†¬į–†¬Ľ–†—Ď–°–Ź'], ['hips', '–†‚Äė–°‚Äė–†“Ď–°–ā–†¬į'],
            ['sleeve', '–†‚ÄĚ–†¬Ľ–†—Ď–†–Ö–†¬į –°–ā–°—ď–†—Ē–†¬į–†–Ü–†¬į'], ['shoulder', '–†—ü–†¬Ľ–†¬Ķ–°‚Ä°–†—Ď'], ['height', '–†¬†–†—ē–°–É–°‚Äö'], ['neck', '–†–Ā–†¬Ķ–°–Ź']
          ]; %>
          <% fields.forEach(([key, label]) => { %>
            <div class="form-group">
              <label for="m-<%= key %>"><%= label %></label>
              <input type="number" id="m-<%= key %>" name="<%= key %>" step="0.5" min="0"
                value="<%= m[key] != null ? m[key] : '' %>" placeholder="–°–É–†—ė">
            </div>
          <% }) %>
        </div>
        <div class="form-group">
          <label for="m-notes">–†—ü–°–ā–†—Ď–†—ė–†¬Ķ–°‚Ä°–†¬į–†–Ö–†—Ď–°–Ź</label>
          <textarea id="m-notes" name="notes" rows="2"><%= m.notes || '' %></textarea>
        </div>
        <button type="submit" class="btn btn-luxury">–†–é–†—ē–°‚Ä¶–°–ā–†¬į–†–Ö–†—Ď–°‚Äö–°–ä –†—ė–†¬Ķ–°–ā–†—Ē–†—Ď</button>
      </form>
    </div>

    <div id="fitting" class="dashboard-block reveal">
      <h2>–†‚ÄĒ–†¬į–†—ó–†—Ď–°–É–°–ä –†–Ö–†¬į –†—ó–°–ā–†—Ď–†—ė–†¬Ķ–°–ā–†—Ē–°—ď</h2>
      <div class="fitting-layout">
        <div class="calendar-widget" id="fitting-calendar" data-booked='<%- JSON.stringify(bookedSlots) %>'></div>
        <form method="POST" action="/account/fitting" class="form form-luxury fitting-form" id="fitting-form">
          <input type="hidden" name="appointment_date" id="fitting-date">
          <input type="hidden" name="appointment_time" id="fitting-time">
          <p class="fitting-selected" id="fitting-selected">–†‚Äô–°‚ÄĻ–†¬Ī–†¬Ķ–°–ā–†—Ď–°‚Äö–†¬Ķ –†“Ď–†¬į–°‚Äö–°—ď –†—Ď –†–Ü–°–ā–†¬Ķ–†—ė–°–Ź</p>
          <div class="time-slots" id="time-slots"></div>
          <div class="form-group">
            <label for="fitting-notes">–†—ô–†—ē–†—ė–†—ė–†¬Ķ–†–Ö–°‚Äö–†¬į–°–ā–†—Ď–†‚ĄĖ</label>
            <textarea id="fitting-notes" name="notes" rows="2"></textarea>
          </div>
          <button type="submit" class="btn btn-luxury" id="fitting-submit" disabled>–†‚ÄĒ–†¬į–†—ó–†—Ď–°–É–†¬į–°‚Äö–°–ä–°–É–°–Ź</button>
        </form>
      </div>
      <% if (fittings.length > 0) { %>
        <div class="fitting-list mt-md">
          <% fittings.forEach(f => { %>
            <div class="fitting-item">
              <span><%= new Date(f.appointment_date).toLocaleDateString('ru-RU') %></span>
              <span><%= f.appointment_time %></span>
              <span class="status status-<%= f.status %>"><%= f.status === 'pending' ? '–†—õ–†¬∂–†—Ď–†“Ď–†¬į–†¬Ķ–°‚Äö' : f.status %></span>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

