# Скопируйте в .env.local и заполните перед запуском
PORT=3000
SITE_URL=https://ваш-домен.ru
SESSION_SECRET=замените-на-длинную-случайную-строку
ADMIN_LOGIN=admin
ADMIN_PASSWORD=надёжный-пароль

# Ключ мобильного приложения GP Админ (тот же в Render → Environment)
